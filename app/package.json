{
  "name": "tbh-companion",
  "version": "1.10.0",
  "description": "TBH: Task Bar Hero companion - live XP/gold tracking and inventory valuation.",
  "author": "lucasfevi",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --config vitest.bench.config.ts",
    "bench:ci": "node scripts/bench-ci.mjs",
    "qa": "node scripts/qa-gate.mjs",
    "qa:dev": "node scripts/qa-dev.mjs",
    "regenerate-gamedata": "vitest run --config vitest.regenerate.config.ts",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.electron.tbh-companion",
    "productName": "TBH Companion",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "lucasfevi",
      "repo": "tbh-companion"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../data",
        "to": "data"
      },
      {
        "from": "../docs/design/icons/tray-icon-32.png",
        "to": "tray-icon-32.png"
      },
      {
        "from": "../docs/design/icons/companion-icon-256.png",
        "to": "companion-icon-256.png"
      },
      {
        "from": "../docs/design/icons/companion-icon.ico",
        "to": "companion-icon.ico"
      },
      {
        "from": "resources/sounds",
        "to": "sounds"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../docs/design/icons/companion-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "tbh-companion-setup-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
