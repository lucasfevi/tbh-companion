{
  "name": "tbh-companion",
  "version": "1.0.1",
  "description": "TBH: Task Bar Hero companion - live XP/gold tracking and inventory valuation.",
  "author": "lucasfevi",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "node scripts/qa-gate.mjs",
    "qa:dev": "node scripts/qa-dev.mjs",
    "regenerate-gamedata": "vitest run --config vitest.regenerate.config.ts",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "build": {
    "productName": "TBH Companion",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../data",
        "to": "data"
      },
      {
        "from": "../docs/design/icons/concept-companion-512.png",
        "to": "tray-icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../docs/design/icons/concept-companion-512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
